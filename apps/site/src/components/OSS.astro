---
import { Plug } from "@lucide/astro"
---

<section class="section section-divide">
  <div class="page">
    <div class="section-head">
      <div class="eyebrow"><span class="dot"></span> open source</div>
      <h2>Built in the open. Shipped by operators.</h2>
    </div>
    <div class="oss-strip">
      <div class="oss">
        <div class="oss-head">
          <svg viewBox="0 0 16 16" width="22" height="22" fill="currentColor" class="ic" aria-hidden="true">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
          <h4>muleta-dev/muleta</h4>
        </div>
        <p>
          Apache 2.0. Every commit public, every issue tracked, every RFC discussed in the open.
        </p>
        <div class="stat-row">
          <div class="stat"><div class="v">—</div><div class="l">stars</div></div>
          <div class="stat"><div class="v">—</div><div class="l">forks</div></div>
          <div class="stat"><div class="v">—</div><div class="l">contribs</div></div>
        </div>
      </div>
      <div class="oss">
        <div class="oss-head">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" class="ic" aria-hidden="true">
            <path
              d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515a.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0a12.64 12.64 0 0 0-.617-1.25a.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057a19.9 19.9 0 0 0 5.993 3.03a.078.078 0 0 0 .084-.028a14.09 14.09 0 0 0 1.226-1.994a.076.076 0 0 0-.041-.106a13.107 13.107 0 0 1-1.872-.892a.077.077 0 0 1-.008-.128a10.2 10.2 0 0 0 .372-.292a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127a12.299 12.299 0 0 1-1.873.892a.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028a19.839 19.839 0 0 0 6.002-3.03a.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.956-2.419 2.157-2.419c1.21 0 2.176 1.096 2.157 2.42c0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.955-2.419 2.157-2.419c1.21 0 2.176 1.096 2.157 2.42c0 1.333-.946 2.418-2.157 2.418z"
            ></path>
          </svg>
          <h4>Discord</h4>
        </div>
        <p>Real humans in #help, RFC reviews in #design, plugin authors showing off in #gallery.</p>
        <div class="stat-row">
          <div class="stat"><div class="v">soon</div><div class="l">members</div></div>
          <div class="stat"><div class="v">~2m</div><div class="l">avg reply</div></div>
        </div>
      </div>
      <div class="oss">
        <div class="oss-head">
          <Plug size={22} class="ic" />
          <h4>Plugin registry</h4>
        </div>
        <p>Community plugins — auth providers, job renderers, alerting backends.</p>
        <div class="stat-row">
          <div class="stat"><div class="v">—</div><div class="l">plugins</div></div>
          <div class="stat"><div class="v">v1</div><div class="l">API</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .oss-strip {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--r-3);
    overflow: hidden;
  }
  .oss {
    background: var(--bg-1);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 220px;
  }
  .oss .oss-head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .oss .oss-head .ic {
    width: 26px;
    height: 26px;
    color: var(--fg);
  }
  .oss .oss-head h4 {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .oss p {
    margin: 0;
    color: var(--fg-2);
    font-size: 13px;
    line-height: 1.55;
  }
  .oss .stat-row {
    display: flex;
    gap: 24px;
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  .oss .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .oss .stat .v {
    font-family: var(--font-mono);
    font-size: 18px;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.01em;
  }
  .oss .stat .l {
    font-size: 10.5px;
    color: var(--fg-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 900px) {
    .oss-strip {
      grid-template-columns: 1fr;
    }
  }
</style>
