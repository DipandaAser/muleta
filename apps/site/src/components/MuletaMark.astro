---
// Custom brand mark — the muleta cape/flag. Not in lucide; kept inline so
// the nav + footer don't pay a separate request.
interface Props {
  size?: number
  class?: string
}

const { size = 22, class: className } = Astro.props
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class={className}
>
  <g color="currentColor">
    <path
      d="M4 20 L4 4 L13 8 L20 5 L20 14 L13 17 L4 20 Z"
      fill="currentColor"
      fill-opacity="0.22"></path>
    <path
      d="M4 4 L4 20"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"></path>
    <path
      d="M4 4 L13 8 L20 5"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"></path>
    <path
      d="M20 5 L20 14 L13 17 L4 20"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"></path>
    <path
      d="M13 8 L13 17"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-opacity="0.5"></path>
  </g>
</svg>
