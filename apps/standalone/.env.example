# muleta standalone — environment template
# Copy to `.env` (or pass via your process manager / docker -e) and fill in.

# Required. Connection string for the Redis that backs your BullMQ queues.
# Examples:
#   redis://localhost:6379
#   redis://:password@redis.internal:6379/0
#   rediss://user:pass@managed.redis.example.com:6380   # TLS
MULETA_REDIS_URL=redis://localhost:6379
