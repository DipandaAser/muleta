{
  "name": "@muleta-dev/standalone",
  "version": "0.0.0",
  "description": "Standalone muleta binary — reads env, binds a port, serves the API.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "node build.mjs",
    "start:prod": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@muleta-dev/core": "workspace:*",
    "@muleta-dev/server": "workspace:*",
    "@muleta-dev/ui": "workspace:*",
    "bullmq": "^5.74.1",
    "hono": "^4.12.14",
    "ioredis": "^5.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0"
  }
}
