{
  "name": "@muleta-dev/core",
  "version": "0.2.0",
  "description": "Core queue registry, event bus, and plugin host for muleta — the operator dashboard for BullMQ.",
  "license": "Apache-2.0",
  "author": "muleta-dev",
  "homepage": "https://muleta.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DipandaAser/muleta.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/DipandaAser/muleta/issues"
  },
  "keywords": [
    "bullmq",
    "redis",
    "queue",
    "dashboard",
    "muleta",
    "monitoring",
    "jobs",
    "workers"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/strip-dev.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm typecheck"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "peerDependencies": {
    "bullmq": "^5",
    "ioredis": "^5"
  },
  "devDependencies": {
    "bullmq": "^5.74.1",
    "ioredis": "^5.10.1",
    "testcontainers": "^11.14.0",
    "vitest": "^4.1.4"
  }
}
