{
  "name": "@muleta/core",
  "version": "0.0.0",
  "description": "Core queue registry, event bus, and plugin host for muleta.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.ts",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "bullmq": "^5",
    "ioredis": "^5"
  },
  "devDependencies": {
    "bullmq": "^5.74.1",
    "ioredis": "^5.10.1",
    "testcontainers": "^11.14.0",
    "vitest": "^4.1.4"
  }
}
