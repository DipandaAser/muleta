{
  "name": "@muleta-dev/server",
  "version": "0.0.0",
  "description": "HTTP handler for muleta Hono-based, framework-agnostic.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.ts",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "hono": "^4",
    "zod": "^4"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^1.3.0",
    "@muleta-dev/core": "workspace:*"
  },
  "devDependencies": {
    "bullmq": "^5.74.1",
    "hono": "^4.12.14",
    "ioredis": "^5.10.1",
    "testcontainers": "^11.14.0",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  }
}
