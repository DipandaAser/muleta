{
  "name": "@muleta-dev/server",
  "version": "0.0.0",
  "description": "Embed the muleta BullMQ dashboard in your Node app — Hono-based handler with framework adapters, ships with the SPA bundled.",
  "license": "Apache-2.0",
  "author": "muleta-dev",
  "homepage": "https://muleta.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DipandaAser/muleta.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/DipandaAser/muleta/issues"
  },
  "keywords": [
    "bullmq",
    "redis",
    "queue",
    "dashboard",
    "muleta",
    "monitoring",
    "jobs",
    "workers",
    "hono",
    "embed"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./express": {
      "types": "./src/express.ts",
      "import": "./src/express.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./src/node.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle-ui.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm typecheck"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./express": {
        "types": "./dist/express.d.ts",
        "import": "./dist/express.js"
      },
      "./node": {
        "types": "./dist/node.d.ts",
        "import": "./dist/node.js"
      }
    }
  },
  "peerDependencies": {
    "hono": "^4",
    "zod": "^4"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^1.3.0",
    "@muleta-dev/core": "workspace:*"
  },
  "devDependencies": {
    "@muleta-dev/ui": "workspace:*",
    "bullmq": "^5.74.1",
    "hono": "^4.12.14",
    "ioredis": "^5.10.1",
    "testcontainers": "^11.14.0",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  }
}
